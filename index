<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
  <title>Skycord</title>
  <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-database-compat.js"></script>
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --blurple:#5865F2;--blurple-hover:#4752c4;--green-360:#23A55A;--green-hover:#1a8a47;
      --yellow-300:#F0B232;--red-400:#F23F43;--grey-500:#80848E;--dark-1:#1E1F22;
      --dark-2:#2B2D31;--dark-3:#313338;--dark-4:#383A40;--dark-5:#43444B;
      --text-light:#DBDEE1;--text-muted:#949BA4;--text-header:#F2F3F5;--hover-bg:#3C3E44;--danger:#ED4245
    }
    body{
      font-family:'Segoe UI','Inter','Whitney',sans-serif;background:var(--dark-3);color:var(--text-light);
      height:100vh;max-height:100vh;overflow:hidden
    }
    .auth-overlay{
      position:fixed;inset:0;background:rgba(0,0,0,0.88);display:flex;align-items:center;
      justify-content:center;z-index:2000;backdrop-filter:blur(6px)
    }
    .auth-overlay.hidden{display:none}
    .auth-box{
      background:var(--dark-2);padding:36px;border-radius:10px;width:420px;max-width:90vw;
      box-shadow:0 20px 50px rgba(0,0,0,0.6);display:flex;flex-direction:column;gap:16px
    }
    .auth-box h1{color:white;text-align:center;font-size:28px;font-weight:700;letter-spacing:-0.5px}
    .auth-box h1 span{background:linear-gradient(135deg,var(--blurple),#7c8aff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .auth-input{
      background:var(--dark-4);border:1px solid var(--dark-5);border-radius:4px;padding:10px 14px;
      color:white;font-size:15px;outline:none;transition:0.2s
    }
    .auth-input:focus{border-color:var(--blurple)}
    .auth-input::placeholder{color:var(--text-muted)}
    .auth-btn{
      background:var(--blurple);color:white;border:none;border-radius:4px;padding:12px;
      font-size:16px;font-weight:600;cursor:pointer;transition:0.2s
    }
    .auth-btn:hover{background:var(--blurple-hover)}
    .auth-btn:disabled{opacity:0.5;cursor:not-allowed}
    .auth-toggle{color:var(--text-muted);font-size:13px;text-align:center;cursor:pointer;user-select:none}
    .auth-toggle span{color:var(--blurple);text-decoration:underline;font-weight:500}
    .error-msg{color:var(--danger);font-size:13px;text-align:center;min-height:18px}
    .app-layout{display:none;height:100vh;width:100%}
    .app-layout.active{display:flex}
    .server-sidebar{
      width:72px;min-width:72px;background:var(--dark-1);display:flex;flex-direction:column;
      align-items:center;padding:12px 0;gap:8px;overflow-y:auto;scrollbar-width:none;flex-shrink:0
    }
    .server-sidebar::-webkit-scrollbar{display:none}
    .server-icon{
      width:48px;height:48px;background:var(--dark-4);border-radius:50%;display:flex;
      align-items:center;justify-content:center;color:var(--text-muted);font-size:20px;
      cursor:pointer;transition:0.15s ease-out;flex-shrink:0;border:none;outline:none;
      user-select:none;position:relative;overflow:hidden
    }
    .server-icon img{width:100%;height:100%;object-fit:cover;border-radius:50%}
    .server-icon:hover,.server-icon.active{border-radius:25%;background:var(--blurple);color:white}
    .server-icon.active img{border-radius:25%}
    .server-icon.add-server{background:var(--dark-4);color:var(--green-360);font-size:28px;font-weight:300}
    .server-icon.add-server:hover{background:var(--green-360);color:white}
    .server-separator{width:32px;height:2px;background:var(--dark-5);border-radius:1px;margin:4px 0}
    .channel-sidebar{
      width:240px;min-width:240px;background:var(--dark-2);display:flex;flex-direction:column;flex-shrink:0
    }
    .channel-header{
      padding:12px 16px;font-size:15px;font-weight:600;color:var(--text-header);
      border-bottom:1px solid rgba(0,0,0,0.2);display:flex;align-items:center;
      justify-content:space-between;height:48px;cursor:pointer
    }
    .channel-list{
      flex:1;overflow-y:auto;padding:8px 0;scrollbar-width:thin;scrollbar-color:var(--dark-5) var(--dark-2)
    }
    .channel-list::-webkit-scrollbar{width:4px}
    .channel-list::-webkit-scrollbar-track{background:transparent}
    .channel-list::-webkit-scrollbar-thumb{background:var(--dark-5);border-radius:2px}
    .category{
      padding:12px 16px 4px;font-size:11px;font-weight:600;text-transform:uppercase;
      color:var(--text-muted);letter-spacing:0.5px;display:flex;align-items:center;justify-content:space-between
    }
    .category .add-channel-btn{
      cursor:pointer;color:var(--text-muted);font-size:16px;padding:0 4px;border-radius:3px;line-height:1
    }
    .category .add-channel-btn:hover{color:white;background:var(--dark-5)}
    .channel-item{
      padding:6px 8px 6px 16px;margin:0 8px;border-radius:4px;display:flex;align-items:center;
      gap:6px;cursor:pointer;color:var(--text-muted);font-size:14px;transition:0.1s
    }
    .channel-item:hover{background:var(--hover-bg);color:var(--text-light)}
    .channel-item.active{background:var(--dark-5);color:white}
    .channel-prefix{font-size:18px;color:var(--grey-500);margin-right:2px}
    .channel-item.active .channel-prefix{color:white}
    .user-panel{
      padding:8px;border-top:1px solid rgba(0,0,0,0.2);display:flex;align-items:center;
      gap:8px;background:#232428;cursor:pointer
    }
    .user-panel:hover{background:var(--dark-5)}
    .user-avatar-small{
      width:32px;height:32px;border-radius:50%;display:flex;align-items:center;
      justify-content:center;font-size:14px;font-weight:bold;color:white;flex-shrink:0;overflow:hidden
    }
    .user-avatar-small img{width:100%;height:100%;object-fit:cover}
    .logout-btn{
      background:none;border:none;color:var(--danger);cursor:pointer;font-size:16px;
      padding:4px 8px;border-radius:4px
    }
    .logout-btn:hover{background:rgba(237,66,69,0.15)}
    .chat-area{flex:1;display:flex;flex-direction:column;background:var(--dark-3);min-width:0}
    .chat-header{
      height:48px;border-bottom:2px solid var(--dark-2);padding:0 16px;display:flex;
      align-items:center;font-weight:600;color:var(--text-header);box-shadow:0 1px 2px rgba(0,0,0,0.1);gap:12px
    }
    .messages-container{
      flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:4px;scroll-behavior:smooth
    }
    .messages-container::-webkit-scrollbar{width:6px}
    .messages-container::-webkit-scrollbar-track{background:transparent}
    .messages-container::-webkit-scrollbar-thumb{background:var(--dark-4);border-radius:3px}
    .message-row{display:flex;margin-top:12px;padding:4px 0;animation:fadeIn 0.2s ease}
    @keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
    .message-avatar{
      width:40px;height:40px;border-radius:50%;margin-right:16px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:16px;
      color:white;user-select:none;overflow:hidden
    }
    .message-avatar img{width:100%;height:100%;object-fit:cover}
    .message-content{flex:1;min-width:0}
    .message-header{display:flex;align-items:baseline;gap:8px;margin-bottom:2px;flex-wrap:wrap}
    .message-author{font-weight:600;font-size:15px}
    .message-time{font-size:11px;color:var(--text-muted);margin-left:4px}
    .message-text{color:var(--text-light);font-size:15px;line-height:1.4;word-wrap:break-word;overflow-wrap:break-word}
    .message-system{text-align:center;color:var(--text-muted);font-size:12px;padding:8px;font-style:italic}
    .chat-input-area{padding:0 16px 24px}
    .input-wrapper{background:var(--dark-4);border-radius:8px;padding:0 16px;display:flex;align-items:center;gap:4px}
    .chat-textarea{
      flex:1;background:transparent;border:none;outline:none;resize:none;color:var(--text-light);
      font-size:15px;font-family:inherit;padding:12px 0;line-height:1.2;max-height:120px
    }
    .chat-textarea::placeholder{color:var(--text-muted)}
    .icon-btn{
      background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:20px;
      padding:6px;border-radius:4px;transition:0.15s;display:flex;align-items:center;justify-content:center;line-height:1
    }
    .icon-btn:hover{background:var(--dark-5);color:white}
    .members-sidebar{
      width:240px;min-width:240px;background:var(--dark-2);display:flex;flex-direction:column;
      flex-shrink:0;border-left:1px solid rgba(0,0,0,0.2)
    }
    .members-header{
      padding:16px;font-size:11px;font-weight:600;text-transform:uppercase;color:var(--text-muted);
      letter-spacing:0.5px;border-bottom:1px solid rgba(0,0,0,0.15)
    }
    .members-list{flex:1;overflow-y:auto;padding:8px}
    .member-item{
      padding:6px 8px;margin:2px 0;border-radius:4px;display:flex;align-items:center;
      gap:10px;font-size:13px;cursor:pointer
    }
    .member-item:hover{background:var(--hover-bg)}
    .member-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
    .member-dot.online{background:var(--green-360)}
    .member-dot.offline{background:var(--grey-500)}
    .modal-overlay{
      position:fixed;inset:0;background:rgba(0,0,0,0.85);display:flex;align-items:center;
      justify-content:center;z-index:3000;backdrop-filter:blur(4px)
    }
    .modal{
      background:var(--dark-2);border-radius:8px;padding:24px;width:440px;max-width:90vw;
      max-height:85vh;overflow-y:auto;box-shadow:0 20px 50px rgba(0,0,0,0.6);display:flex;flex-direction:column;gap:12px
    }
    .modal h3{color:white;font-size:18px;font-weight:600}
    .modal label{color:var(--text-muted);font-size:12px;font-weight:600;text-transform:uppercase}
    .modal input,.modal textarea{
      background:var(--dark-4);border:1px solid var(--dark-5);border-radius:4px;padding:10px;
      color:white;font-size:14px;outline:none;resize:vertical;font-family:inherit
    }
    .modal input:focus,.modal textarea:focus{border-color:var(--blurple)}
    .modal textarea{min-height:60px}
    .btn-row{display:flex;gap:8px}
    .btn{
      padding:8px 16px;border-radius:4px;border:none;cursor:pointer;font-size:14px;
      font-weight:500;transition:0.15s;background:var(--dark-4);color:white;flex:1;text-align:center
    }
    .btn:hover{background:var(--dark-5)}
    .btn.primary{background:var(--blurple)}
    .btn.primary:hover{background:var(--blurple-hover)}
    .btn.success{background:var(--green-360)}
    .btn.success:hover{background:var(--green-hover)}
    .btn.danger{background:var(--danger)}
    .btn.danger:hover{background:var(--red-hover)}
    .profile-avatar-preview{
      width:80px;height:80px;border-radius:50%;display:flex;align-items:center;
      justify-content:center;font-size:32px;font-weight:bold;color:white;align-self:center;overflow:hidden
    }
    .profile-avatar-preview img{width:100%;height:100%;object-fit:cover}
    @media(max-width:900px){.members-sidebar{display:none}}
    @media(max-width:700px){.channel-sidebar{width:180px;min-width:180px}}
  </style>
</head>
<body>

<!-- АВТОРИЗАЦИЯ -->
<div id="auth-overlay" class="auth-overlay">
  <div class="auth-box">
    <h1>☁️ <span>Skycord</span></h1>
    <input type="text" id="auth-nickname" class="auth-input" placeholder="Никнейм" maxlength="30">
    <input type="password" id="auth-password" class="auth-input" placeholder="Пароль">
    <div id="auth-error" class="error-msg"></div>
    <button id="auth-submit-btn" class="auth-btn">Войти</button>
    <div class="auth-toggle" id="auth-toggle">Нет аккаунта? <span>Зарегистрироваться</span></div>
  </div>
</div>

<!-- ОСНОВНОЙ ИНТЕРФЕЙС -->
<div id="app-layout" class="app-layout">
  <nav class="server-sidebar" id="server-sidebar">
    <div class="server-icon active" data-server="home" title="Главная">☁️</div>
    <div class="server-separator"></div>
    <div class="server-icon add-server" id="create-server-btn" title="Создать сервер">+</div>
    <div class="server-icon add-server" id="join-server-btn" title="Присоединиться к серверу" style="font-size:20px;">🔗</div>
  </nav>
  <aside class="channel-sidebar" id="channel-sidebar">
    <div class="channel-header" id="server-name-header"><span>Главная</span></div>
    <div class="channel-list" id="channel-list"></div>
    <div class="user-panel" id="profile-btn">
      <div class="user-avatar-small" id="current-user-avatar" style="background:var(--blurple);">?</div>
      <div style="flex:1;font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" id="current-user-name">Гость</div>
      <button class="logout-btn" id="logout-btn" title="Выйти">⏻</button>
    </div>
  </aside>
  <main class="chat-area">
    <div class="chat-header"><span># <span id="current-channel-name">общий</span></span></div>
    <div class="messages-container" id="message-container"><div class="message-system">Загрузка...</div></div>
    <div class="chat-input-area">
      <div class="input-wrapper">
        <textarea class="chat-textarea" id="chat-input" placeholder="Напишите сообщение..." rows="1"></textarea>
        <button class="icon-btn" id="send-btn" title="Отправить">➤</button>
      </div>
    </div>
  </main>
  <aside class="members-sidebar">
    <div class="members-header">Участники онлайн</div>
    <div class="members-list" id="members-list"></div>
  </aside>
</div>

<!-- МОДАЛЬНЫЕ ОКНА (рендерятся динамически) -->
<div id="modal-container"></div>

<script>
(function(){
'use strict';

const firebaseConfig = {
  apiKey: "AIzaSyAk7LKFocyEzjBI8oWkaZNBIfoFTV1mI_c",
  authDomain: "skycord-ec8c1.firebaseapp.com",
  projectId: "skycord-ec8c1",
  storageBucket: "skycord-ec8c1.firebasestorage.app",
  messagingSenderId: "842442031046",
  appId: "1:842442031046:web:62f44d0f3057e8e6c33cc7",
  databaseURL: "https://skycord-ec8c1-default-rtdb.firebaseio.com"
};

firebase.initializeApp(firebaseConfig);
const db = firebase.database();

// ==================== СОСТОЯНИЕ ====================
let currentUser = null;
let currentServer = 'home';
let currentChannel = 'general';
let messagesRef = null;
let presenceRef = null;
let serversListener = null;
let channelsListener = null;
let membersListener = null;
const userColors = {};
const userAvatars = {};

// ==================== DOM ====================
const dom = {
  authOverlay: document.getElementById('auth-overlay'),
  appLayout: document.getElementById('app-layout'),
  authNickname: document.getElementById('auth-nickname'),
  authPassword: document.getElementById('auth-password'),
  authError: document.getElementById('auth-error'),
  authSubmitBtn: document.getElementById('auth-submit-btn'),
  authToggle: document.getElementById('auth-toggle'),
  currentUserName: document.getElementById('current-user-name'),
  currentUserAvatar: document.getElementById('current-user-avatar'),
  currentChannelName: document.getElementById('current-channel-name'),
  serverNameHeader: document.getElementById('server-name-header'),
  msgContainer: document.getElementById('message-container'),
  chatInput: document.getElementById('chat-input'),
  sendBtn: document.getElementById('send-btn'),
  logoutBtn: document.getElementById('logout-btn'),
  membersList: document.getElementById('members-list'),
  channelList: document.getElementById('channel-list'),
  serverSidebar: document.getElementById('server-sidebar'),
  modalContainer: document.getElementById('modal-container'),
  profileBtn: document.getElementById('profile-btn'),
  createServerBtn: document.getElementById('create-server-btn'),
  joinServerBtn: document.getElementById('join-server-btn')
};

let isRegisterMode = false;

// ==================== УТИЛИТЫ ====================
async function sha256(m){const e=new TextEncoder();const d=await crypto.subtle.digest('SHA-256',e.encode(m));return Array.from(new Uint8Array(d)).map(b=>b.toString(16).padStart(2,'0')).join('')}
function generateColor(n){if(userColors[n])return userColors[n];let h=0;for(let i=0;i<n.length;i++){h=n.charCodeAt(i)+((h<<5)-h);h=h&h}const hue=Math.abs(h)%360;const s=50+(Math.abs(h>>8)%30);const l=38+(Math.abs(h>>16)%20);const c=`hsl(${hue},${s}%,${l}%)`;userColors[n]=c;return c}
function escapeHTML(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML}
function fmtText(t){let e=escapeHTML(t);e=e.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');e=e.replace(/\*(.+?)\*/g,'<em>$1</em>');e=e.replace(/`(.+?)`/g,'<code style="background:#2B2D31;padding:2px 5px;border-radius:3px;font-family:monospace;font-size:13px;">$1</code>');return e}
function timeStr(ts){const d=ts?new Date(ts):new Date();return `${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`}
function sanitize(n){return n.replace(/[^a-zA-Z0-9а-яА-ЯёЁ_\- ]/g,'').trim().toLowerCase()}
function genId(){return Date.now().toString(36)+Math.random().toString(36).substr(2,6)}

// ==================== МОДАЛЬНЫЕ ОКНА ====================
function showModal(title, bodyHTML, buttons){return new Promise((resolve)=>{const overlay=document.createElement('div');overlay.className='modal-overlay';overlay.innerHTML=`<div class="modal"><h3>${title}</h3>${bodyHTML}<div class="btn-row">${buttons.map(b=>`<button class="btn ${b.cls||''}" data-action="${b.action}">${b.text}</button>`).join('')}</div></div>`;overlay.addEventListener('click',(e)=>{if(e.target===overlay){overlay.remove();resolve(null)}});overlay.querySelectorAll('.btn').forEach(btn=>{btn.addEventListener('click',()=>{overlay.remove();resolve({action:btn.dataset.action,values:{}});const inputs=overlay.querySelectorAll('input,textarea');inputs.forEach(inp=>{resolve._values=resolve._values||{};resolve._values[inp.id||inp.placeholder]=inp.value})})});const firstInput=overlay.querySelector('input');if(firstInput)firstInput.focus();document.body.appendChild(overlay);const origResolve=resolve;resolve=function(v){if(v&&v.values===undefined){const vals={};overlay.querySelectorAll('input,textarea').forEach(inp=>{const key=inp.id||inp.placeholder;vals[key]=inp.value});v.values=vals}overlay.remove();origResolve(v)};resolve._values={}})}
function closeAllModals(){document.querySelectorAll('.modal-overlay').forEach(m=>m.remove())}

// ==================== СЕССИЯ ====================
function saveSession(n){sessionStorage.setItem('skycord_session',JSON.stringify({nickname:n,timestamp:Date.now()}))}
function getSession(){try{return JSON.parse(sessionStorage.getItem('skycord_session'))}catch(e){return null}}
function clearSession(){sessionStorage.removeItem('skycord_session')}

// ==================== АВАТАР (Base64 загрузка) ====================
function uploadAvatar(nickname){return new Promise((resolve)=>{const input=document.createElement('input');input.type='file';input.accept='image/*';input.onchange=async()=>{const file=input.files[0];if(!file)return resolve(null);if(file.size>500*1024){alert('Максимальный размер 500 КБ');return resolve(null)}const reader=new FileReader();reader.onload=async(e)=>{const img=new Image();img.onload=()=>{const canvas=document.createElement('canvas');const size=Math.min(img.width,img.height,128);canvas.width=size;canvas.height=size;const ctx=canvas.getContext('2d');const sx=(img.width-size)/2;const sy=(img.height-size)/2;ctx.drawImage(img,sx,sy,size,size,0,0,size,size);resolve(canvas.toDataURL('image/jpeg',0.7))};img.src=e.target.result};reader.readAsDataURL(file)};input.click()})}

// ==================== АУТЕНТИФИКАЦИЯ ====================
function updateAuthUI(){dom.authSubmitBtn.textContent=isRegisterMode?'Зарегистрироваться':'Войти';dom.authToggle.innerHTML=isRegisterMode?'Уже есть аккаунт? <span>Войти</span>':'Нет аккаунта? <span>Зарегистрироваться</span>';dom.authError.textContent='';dom.authSubmitBtn.disabled=false}
async function handleAuth(){
  const raw=dom.authNickname.value.trim();const pass=dom.authPassword.value.trim();
  if(!raw||!pass){dom.authError.textContent='Заполните все поля';return}
  const nick=sanitize(raw);
  if(nick.length<2){dom.authError.textContent='Никнейм минимум 2 символа';return}
  if(pass.length<4){dom.authError.textContent='Пароль минимум 4 символа';return}
  dom.authSubmitBtn.disabled=true;dom.authError.textContent='';
  try{
    const snap=await db.ref('users/'+nick).once('value');const data=snap.val();
    if(isRegisterMode){
      if(data){dom.authError.textContent='Никнейм занят';dom.authSubmitBtn.disabled=false;return}
      const hash=await sha256(pass+'skycord_salt_'+nick);
      await db.ref('users/'+nick).set({nickname:nick,passwordHash:hash,color:generateColor(nick),avatar:'',bio:'',status:'online',createdAt:firebase.database.ServerValue.TIMESTAMP});
      loginUser(nick);
    }else{
      if(!data){dom.authError.textContent='Пользователь не найден';dom.authSubmitBtn.disabled=false;return}
      const hash=await sha256(pass+'skycord_salt_'+nick);
      if(data.passwordHash!==hash){dom.authError.textContent='Неверный пароль';dom.authSubmitBtn.disabled=false;return}
      loginUser(nick);
    }
  }catch(e){dom.authError.textContent='Ошибка соединения';dom.authSubmitBtn.disabled=false}
}
function loginUser(nickname){currentUser={nickname:nickname,color:generateColor(nickname)};saveSession(nickname);dom.authOverlay.classList.add('hidden');dom.appLayout.classList.add('active');dom.authNickname.value='';dom.authPassword.value='';updateUserUI();setupPresence();attachServersListener();switchServer('home')}
async function logout(){
  if(presenceRef){presenceRef.onDisconnect().cancel();presenceRef.remove();presenceRef=null}
  detachAllListeners();currentUser=null;clearSession();dom.appLayout.classList.remove('active');dom.authOverlay.classList.remove('hidden');dom.authError.textContent='';dom.authSubmitBtn.disabled=false;
  dom.msgContainer.innerHTML='<div class="message-system">Войдите в аккаунт</div>'
}

// ==================== UI ЮЗЕРА ====================
async function updateUserUI(){
  if(!currentUser)return;
  dom.currentUserName.textContent=currentUser.nickname;
  const snap=await db.ref('users/'+currentUser.nickname).once('value');
  const data=snap.val();
  if(data){
    currentUser.color=data.color;currentUser.avatar=data.avatar;currentUser.bio=data.bio;
    userAvatars[currentUser.nickname]=data.avatar;
    if(data.avatar){dom.currentUserAvatar.innerHTML=`<img src="${data.avatar}" alt="">`}
    else{dom.currentUserAvatar.innerHTML=currentUser.nickname[0].toUpperCase();dom.currentUserAvatar.style.background=data.color}
  }else{
    dom.currentUserAvatar.innerHTML=currentUser.nickname[0].toUpperCase();dom.currentUserAvatar.style.background=currentUser.color;
  }
}

// ==================== ПРИСУТСТВИЕ ====================
function setupPresence(){
  if(!currentUser)return;
  if(presenceRef){presenceRef.onDisconnect().cancel();presenceRef.remove()}
  presenceRef=db.ref('presence/'+currentUser.nickname);
  presenceRef.set({nickname:currentUser.nickname,color:currentUser.color,avatar:currentUser.avatar||'',lastSeen:firebase.database.ServerValue.TIMESTAMP});
  presenceRef.onDisconnect().remove();
}
function listenMembers(serverId){
  if(membersListener)membersListener();
  membersListener=db.ref('presence').on('value',async(snapshot)=>{
    const users=snapshot.val();dom.membersList.innerHTML='';
    if(!users){dom.membersList.innerHTML='<div style="text-align:center;color:var(--text-muted);padding:20px;font-size:13px;">Нет пользователей</div>';return}
    if(serverId!=='home'){
      const serverSnap=await db.ref('servers/'+serverId+'/members').once('value');
      const members=serverSnap.val()||{};
      const filtered={};Object.entries(users).forEach(([n,d])=>{if(members[n])filtered[n]=d});
      renderMembersList(filtered);
    }else{renderMembersList(users)}
  });
}
function renderMembersList(users){
  dom.membersList.innerHTML='';
  const entries=Object.entries(users);
  if(entries.length===0){dom.membersList.innerHTML='<div style="text-align:center;color:var(--text-muted);padding:20px;font-size:13px;">Нет пользователей</div>';return}
  entries.sort((a,b)=>a[0].localeCompare(b[0]));
  entries.forEach(([nickname,data])=>{
    const div=document.createElement('div');div.className='member-item';
    const color=data.color||generateColor(nickname);
    const avatar=data.avatar||'';
    const isMe=currentUser&&nickname===currentUser.nickname;
    const avatarHTML=avatar?`<img src="${avatar}" alt="">`:nickname[0].toUpperCase();
    div.innerHTML=`<div class="member-dot online"></div><div class="user-avatar-small" style="background:${color};width:28px;height:28px;font-size:12px;">${avatarHTML}</div><span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;${isMe?'color:var(--blurple);':''}">${escapeHTML(nickname)}${isMe?' (вы)':''}</span>`;
    dom.membersList.appendChild(div);
  });
}

// ==================== СЕРВЕРЫ ====================
function attachServersListener(){
  if(serversListener)db.ref('servers').off('value',serversListener);
  serversListener=db.ref('servers').on('value',(snapshot)=>{
    const servers=snapshot.val();
    dom.serverSidebar.innerHTML='<div class="server-icon active" data-server="home" title="Главная">☁️</div><div class="server-separator"></div>';
    if(servers){
      Object.entries(servers).forEach(([id,data])=>{
        if(data.members&&data.members[currentUser?.nickname]){
          const iconDiv=document.createElement('div');
          iconDiv.className='server-icon'+(id===currentServer?' active':'');
          iconDiv.dataset.server=id;
          iconDiv.title=data.name;
          if(data.icon&&data.icon.startsWith('data:image')){iconDiv.innerHTML=`<img src="${data.icon}" alt="">`}
          else{iconDiv.textContent=data.icon||data.name[0].toUpperCase()}
          iconDiv.addEventListener('click',()=>switchServer(id));
          dom.serverSidebar.appendChild(iconDiv);
        }
      });
    }
    dom.serverSidebar.innerHTML+='<div class="server-separator"></div><div class="server-icon add-server" id="create-server-btn" title="Создать сервер">+</div><div class="server-icon add-server" id="join-server-btn" title="Присоединиться" style="font-size:20px;">🔗</div>';
    document.getElementById('create-server-btn').addEventListener('click',openCreateServerModal);
    document.getElementById('join-server-btn').addEventListener('click',openJoinServerModal);
    document.querySelectorAll('#server-sidebar .server-icon[data-server="home"]').forEach(el=>el.addEventListener('click',()=>switchServer('home')));
  });
}

async function switchServer(serverId){
  currentServer=serverId;
  detachChannelsListener();
  if(serverId==='home'){
    dom.serverNameHeader.innerHTML='<span>Главная</span>';
    currentChannel='general';
    dom.currentChannelName.textContent='общий';
    dom.chatInput.placeholder='Напишите сообщение в #общий';
    dom.channelList.innerHTML='<div class="category">Текстовые каналы</div><div class="channel-item active" data-channel="general"><span class="channel-prefix">#</span> общий</div><div class="channel-item" data-channel="random"><span class="channel-prefix">#</span> флудилка</div>';
    document.querySelectorAll('#channel-list .channel-item').forEach(item=>{item.addEventListener('click',()=>{const ch=item.dataset.channel;if(ch)switchChannel(ch,item.textContent.replace('#','').trim())})});
  }else{
    const snap=await db.ref('servers/'+serverId).once('value');
    const data=snap.val();
    if(!data)return switchServer('home');
    dom.serverNameHeader.innerHTML=`<span>${escapeHTML(data.name)}</span>`;
    renderServerChannels(serverId,data.channels||{});
    listenChannels(serverId);
    const firstCh=Object.keys(data.channels||{})[0];
    if(firstCh){
      const chData=data.channels[firstCh];
      currentChannel=firstCh;
      dom.currentChannelName.textContent=chData.name;
      dom.chatInput.placeholder=`Напишите сообщение в #${chData.name}`;
    }
  }
  dom.msgContainer.innerHTML='<div class="message-system">Загрузка сообщений...</div>';
  attachMessagesListener();
  listenMembers(serverId);
  document.querySelectorAll('#server-sidebar .server-icon').forEach(el=>{el.classList.toggle('active',el.dataset.server===serverId)});
}

function renderServerChannels(serverId,channels){
  dom.channelList.innerHTML='<div class="category"><span>Текстовые каналы</span><span class="add-channel-btn" id="add-channel-btn">+</span></div>';
  Object.entries(channels).forEach(([id,data])=>{
    const div=document.createElement('div');
    div.className='channel-item'+(id===currentChannel?' active':'');
    div.dataset.channel=id;
    div.innerHTML=`<span class="channel-prefix">#</span> ${escapeHTML(data.name)}`;
    div.addEventListener('click',()=>switchChannel(id,data.name));
    dom.channelList.appendChild(div);
  });
  const addBtn=document.getElementById('add-channel-btn');
  if(addBtn)addBtn.addEventListener('click',()=>openCreateChannelModal(serverId));
}

function listenChannels(serverId){
  detachChannelsListener();
  channelsListener=db.ref('servers/'+serverId+'/channels').on('value',(snapshot)=>{
    const channels=snapshot.val()||{};
    renderServerChannels(serverId,channels);
    if(!channels[currentChannel]){
      const first=Object.keys(channels)[0];
      if(first){switchChannel(first,channels[first].name)}
      else{dom.currentChannelName.textContent='нет каналов';dom.msgContainer.innerHTML='<div class="message-system">Создайте канал</div>'}
    }
  });
}

function detachChannelsListener(){if(channelsListener){db.ref('servers/'+currentServer+'/channels').off('value',channelsListener);channelsListener=null}}

async function openCreateServerModal(){
  const result=await showModal('Создать сервер',
    '<label>Название сервера</label><input id="server-name" placeholder="Мой сервер" maxlength="30"><label>Иконка (эмодзи)</label><input id="server-icon" placeholder="🎮" maxlength="4">',
    [{text:'Отмена',action:'cancel'},{text:'Создать',action:'create',cls:'primary'}]);
  if(!result||result.action!=='create')return;
  const name=result.values['server-name']?.trim()||'Мой сервер';
  const icon=result.values['server-icon']?.trim()||'💬';
  const serverId=genId();
  await db.ref('servers/'+serverId).set({
    name:escapeHTML(name),icon:icon,owner:currentUser.nickname,
    members:{[currentUser.nickname]:true},
    channels:{[genId()]:{name:'общий',type:'text'}}
  });
  switchServer(serverId);
}

async function openJoinServerModal(){
  const result=await showModal('Присоединиться к серверу',
    '<label>ID сервера</label><input id="server-id" placeholder="Вставьте ID сервера">',
    [{text:'Отмена',action:'cancel'},{text:'Присоединиться',action:'join',cls:'primary'}]);
  if(!result||result.action!=='join')return;
  const serverId=sanitize(result.values['server-id']?.trim()||'');
  if(!serverId){return}
  const snap=await db.ref('servers/'+serverId).once('value');
  if(!snap.val()){alert('Сервер не найден');return}
  await db.ref('servers/'+serverId+'/members/'+currentUser.nickname).set(true);
  switchServer(serverId);
}

async function openCreateChannelModal(serverId){
  const result=await showModal('Создать канал',
    '<label>Название канала</label><input id="channel-name" placeholder="новый-канал" maxlength="30">',
    [{text:'Отмена',action:'cancel'},{text:'Создать',action:'create',cls:'primary'}]);
  if(!result||result.action!=='create')return;
  const name=sanitize(result.values['channel-name']?.trim()||'новый-канал');
  await db.ref('servers/'+serverId+'/channels/'+genId()).set({name:name,type:'text'});
}

// ==================== КАНАЛЫ (home) ====================
function switchChannel(channelId,channelName){
  currentChannel=channelId;
  dom.currentChannelName.textContent=channelName;
  dom.chatInput.placeholder=`Напишите сообщение в #${channelName}`;
  document.querySelectorAll('#channel-list .channel-item').forEach(el=>el.classList.toggle('active',el.dataset.channel===channelId));
  dom.msgContainer.innerHTML='<div class="message-system">Загрузка...</div>';
  attachMessagesListener();
}

// ==================== СООБЩЕНИЯ ====================
function getMessagesPath(){return currentServer==='home'?`messages/home/${currentChannel}`:`messages/${currentServer}/${currentChannel}`}
function attachMessagesListener(){
  detachMessagesListener();
  messagesRef=db.ref(getMessagesPath());
  messagesRef.limitToLast(50).on('value',async(snapshot)=>{
    const messages=snapshot.val();dom.msgContainer.innerHTML='';
    if(!messages){dom.msgContainer.innerHTML='<div class="message-system">Нет сообщений</div>';return}
    const fragment=document.createDocumentFragment();
    for(const[key,msg]of Object.entries(messages)){
      const row=document.createElement('div');row.className='message-row';
      const color=msg.color||generateColor(msg.nickname||'unknown');
      const avatar=userAvatars[msg.nickname]||'';
      const avatarHTML=avatar?`<img src="${avatar}" alt="">`:(msg.nickname||'?')[0].toUpperCase();
      row.innerHTML=`<div class="message-avatar" style="background:${color};">${avatarHTML}</div><div class="message-content"><div class="message-header"><span class="message-author" style="color:${color};">${escapeHTML(msg.nickname||'Unknown')}</span><span class="message-time">${timeStr(msg.timestamp)}</span></div><div class="message-text">${fmtText(msg.text)}</div></div>`;
      fragment.appendChild(row);
    }
    dom.msgContainer.appendChild(fragment);
    dom.msgContainer.scrollTop=dom.msgContainer.scrollHeight;
  });
}
function detachMessagesListener(){if(messagesRef){messagesRef.off('value');messagesRef=null}}
function sendMessage(){
  const text=dom.chatInput.value.trim();
  if(!text||!currentUser)return;
  db.ref(getMessagesPath()).push({nickname:currentUser.nickname,color:currentUser.color,text:text,timestamp:firebase.database.ServerValue.TIMESTAMP});
  dom.chatInput.value='';dom.chatInput.style.height='auto';
}

// ==================== ПРОФИЛЬ ====================
async function openProfileModal(){
  const snap=await db.ref('users/'+currentUser.nickname).once('value');
  const data=snap.val()||{};
  const avatarHTML=data.avatar?`<img src="${data.avatar}" alt="">`:currentUser.nickname[0].toUpperCase();
  const result=await showModal('Редактировать профиль',
    `<div class="profile-avatar-preview" style="background:${data.color||currentUser.color};" id="profile-avatar-preview">${avatarHTML}</div>
     <button class="btn" id="change-avatar-btn" style="margin-top:-8px;">📷 Сменить аватар</button>
     <label>Статус</label>
     <input id="profile-status" value="${escapeHTML(data.status||'online')}" maxlength="50">
     <label>О себе</label>
     <textarea id="profile-bio" maxlength="200">${escapeHTML(data.bio||'')}</textarea>`,
    [{text:'Отмена',action:'cancel'},{text:'Сохранить',action:'save',cls:'primary'}]);
  if(!result||result.action!=='save')return;
  const updates={status:result.values['profile-status']?.trim()||'online',bio:result.values['profile-bio']?.trim()||''};
  await db.ref('users/'+currentUser.nickname).update(updates);
  updateUserUI();
}

// Обработчик смены аватара (делегирование)
document.addEventListener('click',async(e)=>{
  if(e.target.id==='change-avatar-btn'){
    const avatarData=await uploadAvatar(currentUser.nickname);
    if(avatarData){
      await db.ref('users/'+currentUser.nickname).update({avatar:avatarData});
      userAvatars[currentUser.nickname]=avatarData;
      const preview=document.getElementById('profile-avatar-preview');
      if(preview)preview.innerHTML=`<img src="${avatarData}" alt="">`;
      updateUserUI();
    }
  }
});

// ==================== ОБРАБОТЧИКИ ====================
dom.authSubmitBtn.addEventListener('click',handleAuth);
dom.authPassword.addEventListener('keydown',e=>{if(e.key==='Enter')handleAuth()});
dom.authToggle.addEventListener('click',()=>{isRegisterMode=!isRegisterMode;updateAuthUI()});
dom.logoutBtn.addEventListener('click',logout);
dom.sendBtn.addEventListener('click',sendMessage);
dom.chatInput.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage()}});
dom.chatInput.addEventListener('input',()=>{dom.chatInput.style.height='auto';dom.chatInput.style.height=Math.min(dom.chatInput.scrollHeight,120)+'px'});
dom.profileBtn.addEventListener('click',openProfileModal);
dom.createServerBtn?.addEventListener('click',openCreateServerModal);
dom.joinServerBtn?.addEventListener('click',openJoinServerModal);

// ==================== ОЧИСТКА LISTENERS ====================
function detachAllListeners(){
  detachMessagesListener();
  detachChannelsListener();
  if(serversListener){db.ref('servers').off('value',serversListener);serversListener=null}
  if(membersListener){db.ref('presence').off('value',membersListener);membersListener=null}
}

// ==================== ПРОВЕРКА СЕССИИ ====================
async function checkSession(){
  const session=getSession();
  if(session&&session.nickname){
    try{const snap=await db.ref('users/'+session.nickname).once('value');if(snap.val()){loginUser(session.nickname);return}}catch(e){}
    clearSession();
  }
}

// ==================== ИНИЦИАЛИЗАЦИЯ ====================
updateAuthUI();
checkSession();
console.log('Skycord v3.0 initialized');
})();
</script>
